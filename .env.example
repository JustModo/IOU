# Copy to .env and fill with your real signing values
# cp .env.example .env

# Required for signed Android APK build
# Generate once from your keystore file:
#   base64 -w 0 your-release.keystore
# macOS fallback:
#   base64 your-release.keystore | tr -d '\n'
KEYSTORE_BASE64=
KEYSTORE_PASSWORD=
KEY_ALIAS=
KEY_PASSWORD=
